{
  "expo": {
    "name": "Pengaduan Masyarakat",
    "slug": "pengaduan-masyarakat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spamapp",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.pengaduanmasyarakat",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi memerlukan akses kamera untuk mengambil foto bukti pengaduan",
        "NSLocationWhenInUseUsageDescription": "Aplikasi memerlukan akses lokasi untuk mencatat lokasi pengaduan",
        "NSPhotoLibraryUsageDescription": "Aplikasi memerlukan akses galeri untuk memilih foto bukti pengaduan"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.yourname.pengaduanmasyarakat",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "your_google_maps_api_key_optional"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses ke foto untuk upload bukti pengaduan",
          "cameraPermission": "Aplikasi memerlukan akses kamera untuk mengambil foto bukti pengaduan"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikasi memerlukan akses lokasi untuk mencatat lokasi pengaduan"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
