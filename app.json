{
  "expo": {
    "name": "PengaduanApp v2",
    "slug": "PengaduanAppv2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconv2.png",
    "scheme": "pengaduanappv2",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-iconv2.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.PengaduanApp.v2",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi memerlukan akses kamera untuk mengambil foto bukti pengaduan",
        "NSLocationWhenInUseUsageDescription": "Aplikasi memerlukan akses lokasi untuk mencatat lokasi pengaduan",
        "NSPhotoLibraryUsageDescription": "Aplikasi memerlukan akses galeri untuk memilih foto bukti pengaduan"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-iconv2.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.PengaduanAppv2",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi memerlukan akses ke foto untuk upload bukti pengaduan",
          "cameraPermission": "Aplikasi memerlukan akses kamera untuk mengambil foto bukti pengaduan"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikasi memerlukan akses lokasi untuk mencatat lokasi pengaduan"
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1acc88d6-bf14-4b39-a753-6fd3e8ea221a"
      }
    }
  }
}
